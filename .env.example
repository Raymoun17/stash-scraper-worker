# Standalone scraper-worker configuration.
SCRAPER_HOST=0.0.0.0
SCRAPER_PORT=8000
SCRAPER_SERVICE_TOKEN=replace-with-the-same-token-as-the-bff
SCRAPER_BACKEND=playwright-stealth
SCRAPER_MAX_CONCURRENCY=2
SCRAPER_LOG_LEVEL=INFO

# Optional outbound HTTP(S) proxy, for example http://user:pass@host:port.
SCRAPER_PROXY_URL=
